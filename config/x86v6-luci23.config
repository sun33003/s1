# test
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820s=y
CONFIG_GRUB_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y

# wifi ky
# 闭源
CONFIG_PACKAGE_kmod-mt7603e=n
CONFIG_PACKAGE_kmod-mt76x2e=n
CONFIG_PACKAGE_luci-app-mtwifi=n

# 开源
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mt76-core=y

######################################################
# ===== IPv6 内核 =====
CONFIG_IPV6=y
CONFIG_KERNEL_IPV6=y
CONFIG_KERNEL_IPV6_MULTIPLE_TABLES=y
CONFIG_KERNEL_IPV6_SUBTREES=y
CONFIG_KERNEL_IPV6_MROUTE=y

# ===== IPv6 防火墙 =====
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ip6tables-extra=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-reject6=y
CONFIG_PACKAGE_kmod-ipt-nat6=y

# ===== IPv6 DHCP =====
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_ipv6helper=y

# ===== IPv6 NAT =====
CONFIG_PACKAGE_iptables-mod-nat-extra=y
CONFIG_PACKAGE_kmod-nft-nat6=y

# ===== IPv6 隧道 =====
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_6to4=y
CONFIG_PACKAGE_6rd=y
CONFIG_PACKAGE_ds-lite=y
CONFIG_PACKAGE_map=y
CONFIG_PACKAGE_map-t=y

# ===== IPv6 PPP =====
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_ppp-mod-ipv6=y

# ===== IPv6 DNS =====
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ra=y

# ===== IPv6 路由 =====
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ip6tables-nft=y

# ===== IPv6 内核模块 =====
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_kmod-ip6-tunnel=y
CONFIG_PACKAGE_kmod-ip6-gre=y
CONFIG_PACKAGE_kmod-ip6-vti=y

# ===== OpenWrt 基础 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ===== 网络 =====
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-core=y

# ===== DHCP =====
CONFIG_PACKAGE_dnsmasq=y

# ===== 必要工具 =====
CONFIG_PACKAGE_iputils-ping6=y
CONFIG_PACKAGE_traceroute6=y
CONFIG_PACKAGE_tcpdump=y
#################################################
# IPv6 TProxy（透明代理）
#################################################

CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y

# RelayD 无线中继（客户端+AP 混合中继）
CONFIG_PACKAGE_relayd=y
CONFIG_PACKAGE_luci-proto-relay=y

# LuCI 显示 IPv6 状态（可选）
CONFIG_PACKAGE_luci-proto-ipv6=y


# usb
# CONFIG_PACKAGE_kmod-usb2=y
# CONFIG_PACKAGE_kmod-usb3=y
# CONFIG_PACKAGE_kmod-usb-storage=y
# CONFIG_PACKAGE_kmod-usb-storage-extras=y
# CONFIG_PACKAGE_kmod-fs-ext4=y
# CONFIG_PACKAGE_kmod-fs-ntfs=y




# smb net
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-vsftpd=n
CONFIG_PACKAGE_luci-app-zerotier=n
CONFIG_PACKAGE_luci-app-upnp=n
# 定时重启
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_btrfs_progs=n
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_lsblk=n
CONFIG_PACKAGE_luci-app-filetransfer=y

CONFIG_PACKAGE_luci-app-firewall=n
CONFIG_PACKAGE_luci-app-nlbwmon=n
CONFIG_PACKAGE_luci-app-ramfree=n
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-webui=y
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-ng=y
CONFIG_PACKAGE_luci-app-ttyd=n

CONFIG_PACKAGE_luci-app-mosdns=n
# 网络加速器
CONFIG_PACKAGE_luci-app-turboacc=n
# CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=n

CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_openssh-sftp-server=n

#ss
CONFIG_PACKAGE_shadowsocks-libev-ss-local=n
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=n
CONFIG_PACKAGE_shadowsocksr-libev-ssr-check=y
CONFIG_PACKAGE_shadowsocksr-libev-ssr-local=y
CONFIG_PACKAGE_shadowsocksr-libev-ssr-redir=y
CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
CONFIG_PACKAGE_shadowsocks-rust-ssserver=y

######################################################
### ===== SSR Plus 主程序 =====
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y

CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ChinaDNS_NG=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_DNS2SOCKS=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_DNS2SOCKS_RUST=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_IPT2Socks=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Redsocks2=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Simple_Obfs=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Server=y

######################################################

# CONFIG_PACKAGE_luci-app-adguardhome=n
# CONFIG_PACKAGE_adguardhome=n
# CONFIG_PACKAGE_luci-app-wireguard=n

CONFIG_PACKAGE_luci-app-serverchan=n
CONFIG_PACKAGE_luci-theme-material=n
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_luci-app-eqos=n

# 管理 ARP 绑定IP绑定
CONFIG_PACKAGE_luci-app-arpbind=n
# 上网时间控制
CONFIG_PACKAGE_luci-app-accesscontrol=y

CONFIG_PACKAGE_luci-app-adbyby-plus=n
CONFIG_PACKAGE_luci-app-unblockmusic=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-wol=n
